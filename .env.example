PEC_DB_HOST=localhost
PEC_DB_PORT=54323
PEC_DB_NAME=postgres
PEC_DB_USER=esus_monsenhor
PEC_DB_PASSWORD=pass

# --- Configuração MCP e UI ---

# Portas INTERNAS (Container ou Bare Metal)
# Mantenha estas portas sincronizadas com Dockerfile/Healthcheck se rodar em container.
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=5174
FASTMCP_HOST=127.0.0.1
FASTMCP_PORT=5174
UI_HOST=0.0.0.0
UI_PORT=8001

# Portas EXTERNAS (Docker Host)
# Altere estas portas para liberar acesso na máquina host caso as portas padrão estejam em uso.
HOST_UI_PORT=8001
HOST_MCP_PORT=5174

# --- Integração LLM ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Config de teste local (Postgres env vars padrão)
PGHOST=localhost
PGPORT=54323
PGDATABASE=postgres
PGUSER=esus_monsenhor
PGPASSWORD=pass